# ─── Supabase ───────────────────────────────────────────────
# Encontre estes valores em: Supabase Dashboard → Project Settings → API

# URL do projeto (pública, exposta no browser)
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co

# Chave anônima (pública, exposta no browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Chave service_role (SECRETA — apenas no servidor, NUNCA no browser)
# Usada pela API route para inserir leads ignorando RLS.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Site ───────────────────────────────────────────────────
# URL pública do site (usada no Open Graph / metadados).
# Opcional: na Vercel, VERCEL_PROJECT_PRODUCTION_URL é usada como fallback.
NEXT_PUBLIC_SITE_URL=https://paesferreira.com.br
